! Fonts
URxvt.font: xft:Iosevka Term:size=12
URxvt.boldFont: xft:Iosevka Term:bold:size=12

! Transparency
URxvt.background: #313131

! Rendering
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: true
Xft.antialias: true
Xft.rgba: rgb

! Cursor
URxvt.cursorStyle: block
URxvt.cursorBlink: true

! Scrollback
URxvt.saveLines: 50000

! Scrollbar
URxvt.scrollBar: false

! Colors
URxvt.foreground: #ffffff

! Normal colors
URxvt.color0:  #151515
URxvt.color1:  #ac4142
URxvt.color2:  #7e8d50
URxvt.color3:  #e5b566
URxvt.color4:  #6c99ba
URxvt.color5:  #9e4e85
URxvt.color6:  #7dd5cf
URxvt.color7:  #d0d0d0

! Bright colors
URxvt.color8:  #505050
URxvt.color9:  #ac4142
URxvt.color10: #7e8d50
URxvt.color11: #e5b566
URxvt.color12: #6c99ba
URxvt.color13: #9e4e85
URxvt.color14: #7dd5cf
URxvt.color15: #f5f5f5

URxvt.perl-ext-common: default,clipboard,url-select,-keyboard-select

! copy pasting
URxvt.keysym.Control-Shift-C: perl:clipboard:copy
URxvt.keysym.Control-Shift-V: perl:clipboard:paste

! no iso14755
URxvt.iso14755: false
URxvt.iso14755_52: false

! url thingy
URxvt.url-select.launcher: helium
URxvt.keysym.M-u: perl:url-select:select_next
URxvt.url-select.underline: true
