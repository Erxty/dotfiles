{
  "manifest_version": 3,
  "name": "Helium Custom Theme",
  "version": "1.0",
  "description": "Custom theme: #313131 background, #d1d1d1 foreground",
  "theme": {
    "colors": {
      "frame":                              [49, 49, 49],
      "frame_inactive":                     [49, 49, 49],
      "frame_overlay":                      [49, 49, 49],
      "frame_overlay_inactive":             [49, 49, 49],
      "frame_incognito":                    [40, 40, 40],
      "frame_incognito_inactive":           [40, 40, 40],
      "toolbar":                            [49, 49, 49],
      "tab_text":                           [209, 209, 209],
      "tab_background_text":                [160, 160, 160],
      "tab_background_text_inactive":       [140, 140, 140],
      "bookmark_text":                      [209, 209, 209],
      "omnibox_background":                 [62, 62, 62],
      "omnibox_text":                       [209, 209, 209],
      "ntp_background":                     [49, 49, 49],
      "ntp_text":                           [209, 209, 209],
      "ntp_header":                         [62, 62, 62],
      "ntp_link":                           [180, 180, 180],
      "toolbar_button_icon":                [209, 209, 209]
    },
    "images": {
      "theme_frame":            "images/theme_frame.png",
      "theme_frame_inactive":   "images/theme_frame_inactive.png",
      "theme_toolbar":          "images/theme_toolbar.png",
      "theme_tab_background":   "images/theme_tab_background.png",
      "theme_ntp_background":   "images/theme_ntp_background.png"
    },
    "tints": {
      "buttons":                    [-1, -1, 0.8],
      "background_tab":             [-1, -1, -1],
      "frame_inactive":             [-1, -1, -1],
      "frame_incognito":            [-1, -1, -1],
      "frame_incognito_inactive":   [-1, -1, -1]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat":    "no-repeat",
      "ntp_logo_alternate":       1
    }
  }
}
